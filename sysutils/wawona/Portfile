# Allow Cargo.lock flexibility after patching out the waypipe path dependency
build.pre_args-replace \
                    --frozen --offline

depends_build-append \
                    path:bin/pkg-config:pkgconfig \
                    port:xcodegen

depends_lib-append  port:epoll-shim \
                    port:libxkbcommon \
                    path:lib/libssl.dylib:openssl \
                    port:libssh2 \
                    port:wayland \
                    port:waypipe

post-patch {
    # Remove optional waypipe path dependency (not distributed with release tarball)
    reinplace {/^# waypipe: integrated as optional dependency/d} ${worksrcpath}/Cargo.toml
    reinplace "/^waypipe = \{ path/d" ${worksrcpath}/Cargo.toml
    reinplace {/^# Enable in-process waypipe integration$/d} ${worksrcpath}/Cargo.toml
    reinplace {/^waypipe = \["dep:waypipe"\]/d} ${worksrcpath}/Cargo.toml
    reinplace {/^# Enable waypipe with static libssh2 transport/d} ${worksrcpath}/Cargo.toml
    reinplace {/^waypipe-ssh = \["waypipe"/d} ${worksrcpath}/Cargo.toml
    # Remove waypipe from the wawona package's dependency list in Cargo.lock
    reinplace {/ "waypipe",$/d} ${worksrcpath}/Cargo.lock

    # Install macOS-specific Info.plist (the bundled one targets iOS only)
    copy ${filespath}/Info-macOS.plist \
        ${worksrcpath}/src/resources/app-bundle/Info-macOS.plist
}

build.args-append   --bin wawona-cli --lib

post-build {
    # Instantiate the xcodegen project spec with build-time paths
    file copy -force ${filespath}/project-macos.json ${worksrcpath}/project-macos.json
    reinplace "s|@@PREFIX@@|${prefix}|g" ${worksrcpath}/project-macos.json
    reinplace \
        "s|@@RUST_LIB@@|${worksrcpath}/target/[cargo.rust_platform]/release/libwawona.a|g" \
        ${worksrcpath}/project-macos.json

    # Generate Wawona.xcodeproj from the JSON spec
    system -W ${worksrcpath} \
        "${prefix}/bin/xcodegen generate --spec project-macos.json"

    # Locate the real xcodebuild inside Xcode.app.  The /usr/bin/xcodebuild shim
    # fails when xcode-select points at CommandLineTools rather than Xcode.app.
    set xcode_apps [glob -nocomplain /Applications/Xcode*.app]
    if {[llength ${xcode_apps}] == 0} {
        return -code error \
            "Wawona.app requires full Xcode — please install Xcode.app and retry"
    }
    set xcodebuild [lindex ${xcode_apps} 0]/Contents/Developer/usr/bin/xcodebuild

    # Build the macOS app bundle (ad-hoc signed, no provisioning required).
    # Use -derivedDataPath to keep all Xcode state inside the work directory,
    # since $HOME is the MacPorts sandbox and DerivedData would otherwise fail.
    system -W ${worksrcpath} \
        "${xcodebuild} \
            -project Wawona.xcodeproj \
            -scheme Wawona-macOS \
            -configuration Release \
            -derivedDataPath ${worksrcpath}/build/derived \
            CODE_SIGN_STYLE=Manual \
            CODE_SIGN_IDENTITY=- \
            CODE_SIGNING_ALLOWED=YES \
            DEVELOPMENT_TEAM= \
            SYMROOT=${worksrcpath}/build \
            OBJROOT=${worksrcpath}/build/obj"
}

destroot {
    xinstall -m 0755 \
        ${worksrcpath}/target/[cargo.rust_platform]/release/wawona-cli \
        ${destroot}${prefix}/bin/wawona-cli

    xinstall -d ${destroot}${applications_dir}
    copy ${worksrcpath}/build/Release/Wawona.app \
        ${destroot}${applications_dir}/Wawona.app
}

