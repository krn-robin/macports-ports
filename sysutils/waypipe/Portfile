# Allow Cargo.lock to be replaced with the patched version
build.pre_args-replace \
                    --frozen --offline

post-patch {
    # Replace the Cargo.lock with the pre-patched version that includes
    # bindgen and other build-time dependencies added by the macOS patch script
    file copy -force ${filespath}/Cargo.lock.patched ${worksrcpath}/Cargo.lock

    # Apply macOS compatibility patches (phases 2-5: source fixes, memfd,
    # socket wrappers, wrap-gbm/zstd/lz4 stub build scripts, macos_compat module)
    system -W ${worksrcpath} "PATH=${prefix}/libexec/gnubin:\$PATH sh ${filespath}/patch-waypipe-source.sh"

    # The patch script converts waypipe to a staticlib for wawona embedding.
    # Restore the binary target for the standalone MacPorts port.
    reinplace {/^\[lib\]$/,/^crate-type/d} ${worksrcpath}/Cargo.toml
    # Re-add the [[bin]] section that was removed
    # The patch script renames src/main.rs to src/lib.rs, so point the bin at lib.rs
    system "printf '\\n\[\[bin\]\]\\nname = \"waypipe\"\\npath = \"src/lib.rs\"\\n' >> ${worksrcpath}/Cargo.toml"
}

build.args-append   --bin waypipe --no-default-features --features lz4,zstd,dmabuf

destroot {
    xinstall -m 0755 \
        ${worksrcpath}/target/[cargo.rust_platform]/release/waypipe \
        ${destroot}${prefix}/bin/waypipe
}
